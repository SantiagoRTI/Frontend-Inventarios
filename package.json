{
  "name": "frontend-inventarios",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e:fixture": "node e2e/scripts/generate-excel-fixture.mjs",
    "e2e:fixture:cruce": "node e2e/scripts/generate-excel-fixture-cruce.mjs",
    "e2e:auth": "playwright test auth.spec.ts && npm run e2e:summary",
    "e2e:flujo-completo": "npm run e2e:fixture && playwright test flujo-completo.spec.ts && npm run e2e:summary",
    "e2e:cruce": "npm run e2e:fixture:cruce && playwright test cruce-inventario.spec.ts && npm run e2e:summary",
    "e2e:all": "npm run e2e:fixture && npm run e2e:fixture:cruce && playwright test && npm run e2e:summary",
    "e2e": "npm run e2e:all",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report e2e/reports/html",
    "e2e:summary": "node e2e/scripts/generate-summary.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@zxing/library": "^0.21.3",
    "@zxing/ngx-scanner": "^19.0.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^19.1.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.25",
    "@angular/cli": "^19.2.25",
    "@angular/compiler-cli": "^19.2.0",
    "@playwright/test": "^1.60.0",
    "@types/jasmine": "~5.1.0",
    "exceljs": "^4.4.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.7.2"
  }
}
